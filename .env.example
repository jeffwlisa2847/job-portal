# ============================================================
#  .env.example — Environment Variables Template
#
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control (it's in .gitignore).
#
#  For XAMPP local dev:
#    DB_USER=root, DB_PASSWORD=(empty), APP_URL=http://localhost/job-portal/public
# ============================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Job Portal"
APP_ENV=development          # development | production
APP_DEBUG=true
APP_URL=http://localhost/job-portal/public

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=job_portal
DB_USER=root
DB_PASSWORD=

# ── Mail (use Mailtrap for dev: https://mailtrap.io) ─────────────────────────
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=your_mailtrap_username
MAIL_PASS=your_mailtrap_password
MAIL_ENCRYPTION=tls
MAIL_FROM=noreply@jobportal.com
MAIL_FROM_NAME="Job Portal"
