{
    "name": "student/job-recruitment-portal",
    "description": "Final Year Project — Job Recruitment Portal built with PHP 8.2, MySQL, Bootstrap 5",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
